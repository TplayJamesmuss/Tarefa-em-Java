import java.util.Scanner;

public class Exercicio3 {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int num, valor = 1;

        System.out.print("Digite um número: ");
        num = sc.nextInt();

        while (valor <= num) {
            System.out.println(valor);
            valor *= 2;
        }
    }
}

import java.util.Scanner;

public class Exercicio1 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Digite um número inteiro: ");
        int num = sc.nextInt();
        if (num > 20) {
            int metade = num / 2;
            System.out.println("Metade: " + metade);
        }
        sc.close();
    }
}
